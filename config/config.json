{
  "telegram": {
    "streaming_enabled": true,
    "streaming_min_update_ms": 1000,
    "assistant_format": "markdown_to_html",
    "max_file_size_mb": 10,
    "file_download_timeout_ms": 30000,
    "max_concurrent_downloads": 4
  },
  "openai": {
    "auth_mode": "codex",
    "model": "gpt-5.3-codex",
    "models": [
      {
        "id": "gpt-5.3-codex",
        "context_window": 400000,
        "max_output_tokens": 128000,
        "default_thinking": "medium",
        "compaction_tokens": 272000,
        "compaction_threshold": 0.95,
        "aliases": [ "codex" ]
      },
      {
        "id": "gpt-5.4-mini",
        "context_window": 400000,
        "max_output_tokens": 128000,
        "default_thinking": "medium",
        "compaction_tokens": 272000,
        "compaction_threshold": 0.95,
        "aliases": [ "mini" ]
      }
    ],
    "timeout_ms": 45000,
    "max_retries": 2,
    "retry_base_ms": 1500,
    "retry_max_ms": 2500
  },
  "runtime": {
    "log_level": "info",
    "prompt_history_limit": null,
    "default_verbose": "count",
    "tool_loop_max_steps": 150,
    "tool_workflow_timeout_ms": 1200000,
    "tool_command_timeout_ms": 60000,
    "tool_poll_interval_ms": 2000,
    "tool_poll_max_attempts": 5,
    "tool_idle_output_threshold_ms": 8000,
    "tool_heartbeat_interval_ms": 5000,
    "tool_cleanup_grace_ms": 3000,
    "tool_failure_breaker_threshold": 5,
    "session_cache_max_entries": 20,
    "app_log_flush_interval_ms": 250,
    "message_queue_mode": "batch"
  },
  "tools": {
    "default_cwd": "~/.agent-commander",
    "default_shell": "/bin/bash",
    "exec_timeout_ms": 1800000,
    "exec_yield_ms": 10000,
    "process_log_tail_lines": 200,
    "log_path": ".agent-commander/main/tool-calls.jsonl",
    "completed_session_retention_ms": 3600000,
    "max_completed_sessions": 500,
    "max_output_chars": 200000,
    "web_search": {
      "default_preset": "pro-search",
      "presets": [
        { "id": "fast-search", "aliases": [ "fast" ] },
        { "id": "pro-search", "aliases": [ "pro" ] },
        { "id": "deep-research", "aliases": [ "deep" ] },
        { "id": "advanced-deep-research", "aliases": [ "xdeep" ] }
      ]
    }
  },
  "paths": {
    "workspace_root": "~/.agent-commander",
    "conversations_dir": ".agent-commander/main/conversations",
    "stashed_conversations_path": ".agent-commander/main/stashed-conversations.json",
    "active_conversations_path": ".agent-commander/main/active-conversations.json",
    "context_snapshots_dir": ".agent-commander/main/context-snapshots",
    "app_log_path": ".agent-commander/app.log"
  },
  "observability": {
    "enabled": true,
    "log_path": ".agent-commander/observability.jsonl",
    "redaction": {
      "enabled": true,
      "max_string_chars": 4000,
      "redact_keys": [
        "authorization",
        "api_key",
        "chatgpt-account-id",
        "token",
        "secret",
        "password",
        "cookie",
        "set-cookie"
      ]
    }
  },
  "subagents": {
    "enabled": true,
    "default_model": "gpt-5.4-mini",
    "max_concurrent_tasks": 10,
    "default_time_budget_sec": 900,
    "default_max_turns": 30,
    "default_max_total_tokens": 500000,
    "default_heartbeat_interval_sec": 30,
    "default_idle_timeout_sec": 120,
    "default_stall_timeout_sec": 300,
    "default_require_plan_by_turn": 3,
    "recv_max_events": 100,
    "recv_default_wait_ms": 200,
    "await_max_timeout_ms": 30000
  }
}
